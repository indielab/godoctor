{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "name": "godoctor-block-replace",
            "type": "command",
            "command": "${pluginPath}/bin/godoctor hooks intercept",
            "description": "Blocks native replace tool to enforce smart_edit"
          }
        ]
      },
      {
        "matcher": "view_file",
        "hooks": [
          {
            "name": "godoctor-block-read",
            "type": "command",
            "command": "${pluginPath}/bin/godoctor hooks intercept",
            "description": "Blocks native read tool to enforce smart_read"
          }
        ]
      },
      {
        "matcher": "write_to_file",
        "hooks": [
          {
            "name": "godoctor-block-write",
            "type": "command",
            "command": "${pluginPath}/bin/godoctor hooks intercept",
            "description": "Blocks native write tool to enforce smart_edit"
          }
        ]
      },
      {
        "matcher": "run_command",
        "hooks": [
          {
            "name": "godoctor-block-shell",
            "type": "command",
            "command": "${pluginPath}/bin/godoctor hooks intercept",
            "description": "Blocks native shell tool to enforce smart_build"
          }
        ]
      }
    ]
  }
}
